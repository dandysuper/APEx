{
  "manifest_version": 3,
  "name": "APEx",
  "version": "2.0.0",
  "description": "APEx - Advanced Stripe Checkout Automation",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "offscreen",
    "downloads",
    "clipboardWrite",
    "tabs",
    "webNavigation",
    "alarms",
    "proxy",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "script/background.js" },
  "action": { "default_title": "APEx" },
  "content_scripts": [
    {
      "matches": [
        "*://*.stripe.com/*",
        "*://*.stripe.network/*",
        "*://checkout.stripe.com/*",
        "*://pay.krea.ai/*",
        "*://billing.gamma.app/*",
        "*://pay.openai.com/*"
      ],
      "js": ["script/content-main.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.stripe.com/*",
        "*://*.stripe.network/*",
        "*://checkout.stripe.com/*",
        "*://pay.krea.ai/*",
        "*://billing.gamma.app/*",
        "*://pay.openai.com/*"
      ],
      "js": ["script/content.js", "script/content-bincc.js", "script/content-3ds-relay.js"],
      "run_at": "document_end",
      "all_frames": true
    },
    {
      "matches": ["*://*.hcaptcha.com/*", "*://hcaptcha.com/*"],
      "js": ["script/hcaptcha.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.stripe.com/*",
        "*://*.stripe.network/*",
        "*://checkout.stripe.com/*",
        "*://pay.krea.ai/*",
        "*://billing.gamma.app/*",
        "*://pay.openai.com/*"
      ],
      "js": ["script/recaptcha-audio-solver.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["*://*.google.com/recaptcha/*", "*://recaptcha.net/recaptcha/*"],
      "js": ["script/recaptcha-iframe-solver.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "script/inject.js",
        "script/inject-relay.js",
        "script/storage.js",
        "script/card-gen.js",
        "script/autofill.js",
        "script/captcha-solver.js",
        "script/network-monitor.js",
        "styles.css",
        "sounds/hit.wav",
        "icons/icon128.png",
        "safe-test-page.html"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [{ "id": "ruleset_1", "enabled": true, "path": "rules.json" }]
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
